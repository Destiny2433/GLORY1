# SMTP Server Configuration (e.g., smtp.gmail.com for Gmail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True

# SMTP Authentication Credentials
# For Gmail, you must generate and use an App Password rather than your account password.
MAIL_USERNAME=your-sender-email@gmail.com
MAIL_PASSWORD=your-sender-app-password
